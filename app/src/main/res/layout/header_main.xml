<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/page_top_padding"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/brand_logo_width"
                android:layout_height="@dimen/brand_logo_height"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/company_logo_description"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_rnl" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12"
                    android:text="@string/main_eyebrow"
                    android:textColor="@color/accent"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/main_title"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/addFolderButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_primary"
                android:contentDescription="@string/create_folder"
                android:padding="11dp"
                android:src="@drawable/ic_folder_add"
                android:tint="@color/on_accent"
                android:tooltipText="@string/create_folder" />

            <ImageButton
                android:id="@+id/searchButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_secondary"
                android:contentDescription="@string/search_shortcuts"
                android:padding="11dp"
                android:src="@drawable/ic_search"
                android:tint="?attr/colorTextPrimary"
                android:tooltipText="@string/search_shortcuts" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_secondary"
                android:contentDescription="@string/settings"
                android:padding="11dp"
                android:src="@drawable/ic_settings"
                android:tint="?attr/colorTextPrimary"
                android:tooltipText="@string/settings" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/folders_subtitle"
        android:textColor="?attr/colorTextSecondary"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/folders"
        android:textColor="?attr/colorTextPrimary"
        android:textSize="21sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/folderSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="?attr/colorTextSecondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/emptyFolders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_card"
        android:gravity="center"
        android:padding="28dp"
        android:text="@string/no_folders"
        android:textColor="?attr/colorTextSecondary"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
