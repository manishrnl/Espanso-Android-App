<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_horizontal_padding"
        android:paddingTop="@dimen/page_top_padding"
        android:paddingBottom="@dimen/page_bottom_padding">

        <ImageButton
            android:id="@+id/settingsBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="@string/back"
            android:padding="11dp"
            android:src="@drawable/ic_back"
            android:tint="?attr/colorTextPrimary"
            android:tooltipText="@string/back" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_subtitle"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="17dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                tools:ignore="UseCompoundDrawables">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/global_expansion"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/settingsExpansionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_accent_chip"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/settingsExpansionDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="@string/third_party_keyboard_note"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/settingsEnableAccessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_primary"
                android:text="@string/enable_global_expansion"
                android:textAllCaps="false"
                android:textColor="@color/on_accent"
                android:minHeight="50dp"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsChooseKeyboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/choose_keyboard"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary"
                android:minHeight="50dp"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingsRestrictedHelpCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_warning_card"
            android:orientation="vertical"
            android:padding="17dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                tools:ignore="UseCompoundDrawables">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:contentDescription="@null"
                    android:padding="5dp"
                    android:src="@drawable/ic_lock"
                    android:tint="@color/warning" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="@string/restricted_settings_title"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:text="@string/restricted_settings_card_detail"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settingsRestrictedHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/fix_restricted_settings"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary"
                android:minHeight="50dp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="17dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/data_and_shortcuts"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsImport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/import_csv"
                android:textAllCaps="false"
                android:minHeight="50dp"
                android:textColor="?attr/colorTextPrimary" />

            <Button
                android:id="@+id/settingsExport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/export_csv"
                android:textAllCaps="false"
                android:minHeight="50dp"
                android:textColor="?attr/colorTextPrimary" />

            <Button
                android:id="@+id/settingsNewShortcut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/add_unfiled_shortcut"
                android:textAllCaps="false"
                android:minHeight="50dp"
                android:textColor="?attr/colorTextPrimary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="@string/recycle_bin_settings_detail"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/settingsRecycleBin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:background="@drawable/bg_button_secondary"
                android:drawableStart="@drawable/ic_delete"
                android:drawablePadding="9dp"
                android:drawableTint="?attr/colorTextPrimary"
                android:gravity="center"
                android:minHeight="50dp"
                android:text="@string/recycle_bin"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="18dp">

            <ImageView
                android:layout_width="@dimen/developer_logo_width"
                android:layout_height="@dimen/developer_logo_height"
                android:contentDescription="@string/company_logo_description"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_rnl" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/company_name"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/developer_name"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:gravity="center"
                android:text="@string/developer_detail"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settingsDeveloperWebsite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="@drawable/bg_button_secondary"
                android:drawableStart="@drawable/ic_web"
                android:drawablePadding="9dp"
                android:drawableTint="?attr/colorTextPrimary"
                android:gravity="center"
                android:minHeight="50dp"
                android:text="@string/view_developer_projects"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
