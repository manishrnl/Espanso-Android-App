<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="36dp">

        <Button
            android:id="@+id/settingsBackButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:background="@drawable/bg_button_secondary"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="@string/back"
            android:textAllCaps="false"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_subtitle"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="17dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/global_expansion"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/settingsExpansionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_accent_chip"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/settingsExpansionDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="@string/third_party_keyboard_note"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/settingsEnableAccessibility"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_primary"
                android:text="@string/enable_global_expansion"
                android:textAllCaps="false"
                android:textColor="@color/on_accent"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsChooseKeyboard"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/choose_keyboard"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="17dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/data_and_shortcuts"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsImport"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/import_csv"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary" />

            <Button
                android:id="@+id/settingsExport"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/export_csv"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary" />

            <Button
                android:id="@+id/settingsNewShortcut"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/add_unfiled_shortcut"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="17dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appearance_and_fallback"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="@string/appearance_and_fallback_detail"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/settingsAppearance"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/open_appearance"
                android:textAllCaps="false"
                android:textColor="?attr/colorTextPrimary" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
