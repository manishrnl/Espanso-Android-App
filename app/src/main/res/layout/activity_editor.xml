<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/editorTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/keywordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/keyword"
            android:inputType="text"
            android:maxLines="1" />

        <EditText
            android:id="@+id/replacementInput"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:gravity="top|start"
            android:hint="@string/replacement_text"
            android:inputType="textMultiLine|textNoSuggestions"
            android:padding="12dp"
            android:scrollbars="vertical" />

        <CheckBox
            android:id="@+id/replaceAfterSpaceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/replace_after_space" />

        <EditText
            android:id="@+id/positionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/position"
            android:inputType="number"
            android:maxLines="1" />

        <EditText
            android:id="@+id/strategyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/strategy"
            android:inputType="text"
            android:maxLines="1" />

        <EditText
            android:id="@+id/folderInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/folder"
            android:inputType="textCapWords"
            android:maxLines="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/cancelButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/cancel" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/save" />
        </LinearLayout>

        <Button
            android:id="@+id/deleteButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/delete"
            android:textColor="#B91C1C"
            android:visibility="gone" />
    </LinearLayout>

</ScrollView>

