<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="18dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageButton
            android:id="@+id/trashBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="@string/back"
            android:padding="11dp"
            android:src="@drawable/ic_back"
            android:tint="?attr/colorTextPrimary"
            android:tooltipText="@string/back" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/emptyTrashButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_danger_button"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="@string/empty_recycle_bin"
            android:textAllCaps="false"
            android:textColor="?attr/colorDanger"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="@string/recycle_bin"
        android:textColor="?attr/colorTextPrimary"
        android:textSize="29sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/recycle_bin_detail"
        android:textColor="?attr/colorTextSecondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/trashSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/accent"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/emptyTrash"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_card"
        android:gravity="center"
        android:padding="28dp"
        android:text="@string/recycle_bin_empty"
        android:textColor="?attr/colorTextSecondary"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
